# LessonLoop E2E test environment configuration.
#
# Copy to `.env.test` (gitignored) and fill in real values.
# Used by tests/e2e/* via playwright.config.ts → dotenv.config({path:'.env.test'}).

# ─── Frontend target ──────────────────────────────────────────
# The deployed app to run tests against. Production destination
# (post-2026-05-08 migration). The playwright.config.ts has a
# safety guard requiring ALLOW_PRODUCTION_TESTS=true to target
# app.lessonloop.net.
E2E_BASE_URL=https://app.lessonloop.net
ALLOW_PRODUCTION_TESTS=true

# ─── Backend target ───────────────────────────────────────────
# Destination Supabase project (xmrhmxizpslhtkibqyfy) post-migration.
# These are PUBLIC keys (anon + publishable). Never put service-role
# keys in this file.
E2E_SUPABASE_URL=https://xmrhmxizpslhtkibqyfy.supabase.co
E2E_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhtcmhteGl6cHNsaHRraWJxeWZ5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc5MDg3NTUsImV4cCI6MjA5MzQ4NDc1NX0.gt-7cZHx44e6hxRUvf8iSz91Czdk1Jm1-yuJf2_Svlg

# ─── Test user credentials ────────────────────────────────────
# These users are pre-seeded in the destination Supabase (auth.users)
# with passwords reset to E2eTestPass123! on 2026-05-08.
# All members of org_id 25b57950-6c4e-42d8-8089-4942d2bba959
# ("E2E Test Academy"), academy plan, has_completed_onboarding=true.
E2E_OWNER_EMAIL=e2e-owner@test.lessonloop.net
E2E_OWNER_PASSWORD=E2eTestPass123!
E2E_ADMIN_EMAIL=e2e-admin@test.lessonloop.net
E2E_ADMIN_PASSWORD=E2eTestPass123!
E2E_FINANCE_EMAIL=e2e-finance@test.lessonloop.net
E2E_FINANCE_PASSWORD=E2eTestPass123!
E2E_TEACHER_EMAIL=e2e-teacher@test.lessonloop.net
E2E_TEACHER_PASSWORD=E2eTestPass123!
E2E_PARENT_EMAIL=e2e-parent@test.lessonloop.net
E2E_PARENT_PASSWORD=E2eTestPass123!
E2E_PARENT2_EMAIL=e2e-parent2@test.lessonloop.net
E2E_PARENT2_PASSWORD=E2eTestPass123!

# ─── Test org id (for direct seeding/cleanup) ─────────────────
E2E_ORG_ID=25b57950-6c4e-42d8-8089-4942d2bba959

# ─── Stripe test mode (optional, only for payment-flow tests) ─
# Get from https://dashboard.stripe.com/test/apikeys
# (sk_test_... — NOT sk_live_...)
# E2E_STRIPE_TEST_SECRET=sk_test_...
# E2E_STRIPE_TEST_WEBHOOK_SECRET=whsec_...

# ─── Service-role key (RLS-bypassing test seeds) ──────────────
# Used by tests/e2e/supabase-admin.ts to insert/update test data
# that RLS would otherwise block under the test-owner JWT.
# Get from: dashboard.supabase.com → Settings → API → service_role
# DO NOT commit. NEVER use in frontend code.
# E2E_SUPABASE_SERVICE_ROLE_KEY=ey...your-service-role-key-here...
