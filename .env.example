VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ── Supabase Edge Function Secrets (set via `supabase secrets set`) ──
# ANTHROPIC_API_KEY=sk-ant-...          # Required: LoopAssist AI (looopassist-chat, parent-loopassist-chat)
# RESEND_API_KEY=re_...                 # Required: All email sending (invoices, notifications, offers, etc.)
# WAITLIST_JWT_SECRET=...               # Required: Enrolment offer accept/decline tokens
# LOVABLE_API_KEY=...                   # Optional: Marketing chat & CSV import AI mapping (has heuristic fallback)
# FRONTEND_URL=https://app.lessonloop.net  # Optional: Email link base URL (defaults to app.lessonloop.net)
